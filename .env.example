# Database - MySQL
DATABASE_URL="mysql://root:password@localhost:3306/perpustakaan_itk"

# JWT Secret - ganti dengan string random yang panjang
JWT_SECRET="your-super-secret-jwt-key-min-32-chars-change-this"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Perpustakaan ITK"

# Konfigurasi peminjaman (hari)
BORROW_DURATION_DAYS=14
MAX_BORROW_BOOKS=3
MAX_EXTENSION_COUNT=2
EXTENSION_DURATION_DAYS=7
BOOKING_EXPIRY_HOURS=48

# Denda per hari keterlambatan (rupiah)
FINE_PER_DAY=1000

# VAPID Keys untuk Web Push Notification (opsional)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:admin@itk.ac.id"
